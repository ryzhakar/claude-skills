{
  "description": "Dev-discipline lifecycle hooks: review chain enforcement after implementer, spec-reviewer, and code-quality-reviewer completion",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "implementer",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/implementer-stop.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "spec-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/spec-reviewer-stop.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "code-quality-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/code-quality-reviewer-stop.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
